[Unit]
Description=Nova_x-ui Service
After=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/conf.d/Nova_x-ui
Environment="XRAY_VMESS_AEAD_FORCED=false"
Type=simple
WorkingDirectory=/usr/local/Nova_x-ui/
ExecStart=/usr/local/Nova_x-ui/Nova_x-ui
ExecReload=kill -USR1 $MAINPID
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
